{
  "name": "@qa/tests",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:sanity": "playwright test --grep @sanity",
    "test:regression": "playwright test --grep @regression",
    "test:feature": "playwright test --grep",
    "test:ui": "playwright test --ui",
    "test:mobile": "playwright test --project chromium-mobile --project webkit-mobile",
    "test:tablet": "playwright test --project tablet-ipad --project tablet-android",
    "test:webkit": "playwright test --project webkit",
    "test:visual": "playwright test --project visual --project tablet-visual",
    "test:a11y": "playwright test --grep @a11y",
    "test:update-snapshots": "playwright test --project visual --project tablet-visual --update-snapshots",
    "perf:lighthouse": "playwright test --project lighthouse-perf",
    "perf:all": "pnpm perf:lighthouse"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@faker-js/faker": "^9.9.0",
    "@playwright/test": "^1.60.0",
    "@qa/api": "workspace:*",
    "@qa/config": "workspace:*",
    "@qa/contracts": "workspace:*",
    "@qa/db": "workspace:*",
    "@qa/web": "workspace:*",
    "dotenv": "^16.6.1",
    "lighthouse": "^13.3.0",
    "playwright-lighthouse": "^4.0.0",
    "web-vitals": "^5.3.0"
  }
}
