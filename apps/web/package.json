{
  "name": "@qa/web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "dev": "dotenv -e ../../.env -- next dev -p 3000",
